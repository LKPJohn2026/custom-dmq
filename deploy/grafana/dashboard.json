{
  "title": "custom-dmq Broker",
  "panels": [
    {
      "title": "Produce requests/s",
      "type": "graph",
      "targets": [{ "expr": "rate(dmq_produce_requests_total[1m])" }]
    },
    {
      "title": "Fetch requests/s",
      "type": "graph",
      "targets": [{ "expr": "rate(dmq_fetch_requests_total[1m])" }]
    },
    {
      "title": "Produce latency p99 (ms)",
      "type": "graph",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(dmq_produce_latency_ms_bucket[5m]))" }]
    },
    {
      "title": "Fetch latency p99 (ms)",
      "type": "graph",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(dmq_fetch_latency_ms_bucket[5m]))" }]
    }
  ]
}
